 s11_card = blank(800, 420) -> card_bg();
 s11_l1 = text("std::core    — brightness, contrast, gamma, clamp", "test_inputs/georgia.ttf", 22, 0, 230, 230);
 s11_l2 = text("std::color   — sepia, warm, cool, vivid, vintage",  "test_inputs/georgia.ttf", 22, 140, 220, 140);
 s11_l3 = text("std::effects — dramatic, dream, cinematic, bloom",   "test_inputs/georgia.ttf", 22, 255, 210, 80);
 s11_l4 = text("std::image   — posterize, fade, monochrome",         "test_inputs/georgia.ttf", 22, 180, 140, 255);
 s11_l5 = text("std::vision  — (coming soon)",                       "test_inputs/georgia.ttf", 22, 90, 100, 130);
 s11_l6 = text("std::mask    — (coming soon)",                       "test_inputs/georgia.ttf", 22, 90, 100, 130);
 s11_note = text("Import any module in one line.", "test_inputs/georgia.ttf", 30, 140, 148, 180);
 s11 = s11_bg
    -> blend(140, 130, s11_heading, 1.0)
    -> blend(140, 216, s11_sub,     0.88)
    -> blend(140, 270, s11_rule,    1.0)
    -> blend(140, 306, s11_card,    0.95)
    -> blend(165, 332, s11_l1,      1.0)
    -> blend(165, 380, s11_l2,      1.0)
    -> blend(165, 428, s11_l3,      1.0)
    -> blend(165, 476, s11_l4,      1.0)
    -> blend(165, 524, s11_l5,      0.6)
    -> blend(165, 572, s11_l6,      0.6)
    -> blend(140, 780, s11_note,    0.85);

export(s11, "Outputs/slide_11_stdlib.png");

// ─────────────────────────────────────────────────────────────────────────────
// SLIDE 12 — "The Pipe Operator" — philosophy slide, minimal design
// ─────────────────────────────────────────────────────────────────────────────
 s12_bg = blank(1080, 1080)
    -> navy_bg()
    -> radial_purple_glow(0.7)
    -> vignette(1.3)
    -> grain(5);

// Large decorative "->" using a gradient strip
 s12_deco = blank(800, 6) -> horizontal_gradient();
 s12_hero  = text("->", "test_inputs/georgia.ttf", 200, 0, 230, 230);
 s12_h1    = text("The pipe operator.", "test_inputs/georgia.ttf", 56, 210, 215, 235);
 s12_h2    = text("Your image flows through every stage.", "test_inputs/georgia.ttf", 34, 140, 148, 180);
 s12_h3    = text("Each filter sees the result of the last.", "test_inputs/georgia.ttf", 30, 110, 118, 155);
 s12 = s12_bg
    -> blend(290, 160, s12_hero,  1.0)
    -> blend(140, 440, s12_deco,  1.0)
    -> blend(140, 468, s12_h1,    1.0)
    -> blend(140, 548, s12_h2,    0.9)
    -> blend(140, 608, s12_h3,    0.75);

export(s12, "Outputs/slide_12_pipe.png");

// ─────────────────────────────────────────────────────────────────────────────
// SLIDE 13 — "Blend & Composite" — compositing showcase
// ─────────────────────────────────────────────────────────────────────────────
 s13_bg = blank(1080, 1080)
    -> navy_bg()
    -> radial_cyan_glow(0.3)
    -> vignette(1.0)
    -> grain(3);

 s13_heading = text("Blend & Composite", "test_inputs/georgia.ttf", 64, 140, 60, 220);
 s13_rule    = blank(580, 2) -> rule_cyan();
 s13_card    = blank(800, 280) -> card_bg();
 s13_c1 = text("canvas = blank(1080, 1080);",              "test_inputs/georgia.ttf", 26, 0, 230, 230);
 s13_c2 = text("logo   = load('logo.png');",             "test_inputs/georgia.ttf", 26, 220, 225, 240);
 s13_c3 = text("label  = text('Hello', font, 48, ...);", "test_inputs/georgia.ttf", 26, 220, 225, 240);
 s13_c4 = text("canvas -> blend(100, 400, logo,  1.0)",    "test_inputs/georgia.ttf", 26, 140, 220, 140);
 s13_c5 = text("       -> blend(100, 700, label, 0.9);",   "test_inputs/georgia.ttf", 26, 140, 220, 140);
 s13_note = text("Build any layout — no graphic editor needed.", "test_inputs/georgia.ttf", 30, 140, 148, 180);
 s13 = s13_bg
    -> blend(140, 148, s13_heading, 1.0)
    -> blend(140, 235, s13_rule,    1.0)
    -> blend(140, 272, s13_card,    0.95)
    -> blend(165, 300, s13_c1,      1.0)
    -> blend(165, 340, s13_c2,      1.0)
    -> blend(165, 378, s13_c3,      1.0)
    -> blend(165, 430, s13_c4,      1.0)
    -> blend(165, 468, s13_c5,      1.0)
    -> blend(140, 640, s13_note,    0.85);

export(s13, "Outputs/slide_13_blend.png");

// ─────────────────────────────────────────────────────────────────────────────
