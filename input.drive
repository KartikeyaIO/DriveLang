 s14_rule_g  = blank(800, 4) -> horizontal_gradient();
 s14_card = blank(800, 340) -> card_bg();
 s14_l1   = text("Bytecode VM — zero interpreter overhead",     "test_inputs/georgia.ttf", 30, 0, 230, 230);
 s14_l2   = text("Per-pixel parallelism via Rayon",             "test_inputs/georgia.ttf", 30, 0, 230, 230);
 s14_l3   = text("Filters compile to typed instruction sets",   "test_inputs/georgia.ttf", 30, 0, 230, 230);
 s14_l4   = text("RGBA canonical — format-safe pipelines",      "test_inputs/georgia.ttf", 30, 0, 230, 230);
 s14_l5   = text("WASM target in progress",                     "test_inputs/georgia.ttf",   28, 140, 148, 180);
