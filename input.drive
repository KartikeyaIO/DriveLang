// ─────────────────────────────────────────────────────────────────────────────
// DriveLang Instagram Launch Post — 15 Slides
// Dark tech aesthetic: deep navy bg, cyan + purple accents
// Canvas: 1080x1080 (square insta format)
// ─────────────────────────────────────────────────────────────────────────────

import "stdlib/core.drive" as core;
import "stdlib/color.drive" as color;
import "stdlib/effects.drive" as effects;

// ── Shared palette filters ────────────────────────────────────────────────────

// Deep navy background: RGB(10, 12, 30)
filter navy_bg() {
    r = 10;
    g = 12;
    b = 30;
    a = 255;
}

// Vivid cyan accent: RGB(0, 230, 230)
filter cyan_fill() {
    r = 0;
    g = 230;
    b = 230;
    a = 255;
}

// Purple accent: RGB(140, 60, 220)
filter purple_fill() {
    r = 140;
    g = 60;
    b = 220;
    a = 255;
}

// Soft white for body text: RGB(220, 225, 240)
filter white_fill() {
    r = 220;
    g = 225;
    b = 240;
    a = 255;
}

// Dark card panel: RGB(18, 22, 48)
filter card_bg() {
    r = 18;
    g = 22;
    b = 48;
    a = 245;
}

// Thin cyan rule / divider: RGB(0, 200, 210)
filter rule_cyan() {
    r = 0;
    g = 200;
    b = 210;
    a = 255;
}

// Gradient helper: radial glow from center (purple core → navy edge)
filter radial_purple_glow(strength) {
    let cx = width / 2;
    let cy = height / 2;
    let dx = x - cx;
    let dy = y - cy;
    let dist = sqrt(dx * dx + dy * dy);
    let max_dist = sqrt(cx * cx + cy * cy);
    let nd = dist / max_dist;
    let glow_r = 120 * (1.0 - nd);
    let glow_g = 10 * (1.0 - nd);
    let glow_b = 200 * (1.0 - nd * 0.4);
    r = clamp(r * (1.0 - strength) + glow_r * strength, 0, 255);
    g = clamp(g * (1.0 - strength) + glow_g * strength, 0, 255);
    b = clamp(b * (1.0 - strength) + glow_b * strength, 0, 255);
}

// Gradient helper: radial cyan glow
filter radial_cyan_glow(strength) {
    let cx = width / 2;
    let cy = height / 2;
    let dx = x - cx;
    let dy = y - cy;
    let dist = sqrt(dx * dx + dy * dy);
    let max_dist = sqrt(cx * cx + cy * cy);
    let nd = dist / max_dist;
    let glow_r = 0;
    let glow_g = 200 * (1.0 - nd * 0.6);
    let glow_b = 220 * (1.0 - nd * 0.3);
    r = clamp(r * (1.0 - strength) + glow_r * strength, 0, 255);
    g = clamp(g * (1.0 - strength) + glow_g * strength, 0, 255);
    b = clamp(b * (1.0 - strength) + glow_b * strength, 0, 255);
}

// Corner-fade vignette darkens edges toward black
filter vignette(strength) {
    let cx = width / 2;
    let cy = height / 2;
    let dx = x - cx;
    let dy = y - cy;
    let dist = sqrt(dx * dx + dy * dy);
    let max_dist = sqrt(cx * cx + cy * cy);
    let nd = dist / max_dist;
    let fade = 1.0 - nd * nd * strength;
    r = clamp(r * fade, 0, 255);
    g = clamp(g * fade, 0, 255);
    b = clamp(b * fade, 0, 255);
}

// Scanline grid for that "terminal" texture (every 6th row slightly darker)
filter scanlines(depth) {
    let row_mod = y - floor(y / 6) * 6;
    if row_mod == 0 {
        r = r - depth;
        g = g - depth;
        b = b - depth;
    }
}

// Subtle noise grain using pixel coords as seed
filter grain(amount) {
    let seed = (x * 1234 + y * 5678) - floor((x * 1234 + y * 5678) / 255) * 255;
    let noise = seed * amount / 255;
    r = clamp(r + noise, 0, 255);
    g = clamp(g + noise, 0, 255);
    b = clamp(b + noise, 0, 255);
}

// Horizontal gradient: left = purple, right = cyan
filter horizontal_gradient() {
    let t = x / width;
    r = clamp(140 * (1.0 - t) + 0 * t, 0, 255);
    g = clamp(60  * (1.0 - t) + 230 * t, 0, 255);
    b = clamp(220 * (1.0 - t) + 230 * t, 0, 255);
    a = 255;
}

// Diagonal gradient: top-left cyan → bottom-right purple
filter diagonal_gradient() {
    let t = (x / width + y / height) / 2;
    r = clamp(0   * (1.0 - t) + 140 * t, 0, 255);
    g = clamp(200 * (1.0 - t) + 40  * t, 0, 255);
    b = clamp(220 * (1.0 - t) + 200 * t, 0, 255);
    a = 255;
}

// ─────────────────────────────────────────────────────────────────────────────
// SLIDE 01 — Cover: "DriveLang" hero with radial purple glow
// ─────────────────────────────────────────────────────────────────────────────
s01_bg = blank(1080, 1080)
    -> navy_bg()
    -> radial_purple_glow(0.85)
    -> vignette(1.2)
    -> scanlines(6)
    -> grain(4);

s01_title = text("DriveLang", "test_inputs/georgia.ttf", 120, 0, 230, 230);
s01_sub   = text("A DSL for Visual Pipelines", "test_inputs/georgia.ttf", 42, 180, 185, 210);
s01_tag   = text("Write filters. Compose pipelines. Ship images.", "test_inputs/georgia.ttf", 28, 100, 110, 150);

s01_rule = blank(800, 3) -> rule_cyan();

s01 = s01_bg
    -> blend(140, 300, s01_title, 1.0)
    -> blend(140, 445, s01_rule, 1.0)
    -> blend(140, 470, s01_sub,  1.0)
    -> blend(140, 540, s01_tag,  0.85);

export(s01, "Outputs/slide_01_cover.png");

// ─────────────────────────────────────────────────────────────────────────────
// SLIDE 02 — "What is DriveLang?" — intro copy
// ─────────────────────────────────────────────────────────────────────────────
s02_bg = blank(1080, 1080)
    -> navy_bg()
    -> radial_cyan_glow(0.5)
    -> vignette(1.0)
    -> grain(3);

s02_label = text("What is DriveLang?", "test_inputs/georgia.ttf", 64, 0, 230, 230);
s02_l1    = text("A mathematical DSL for image + video", "test_inputs/georgia.ttf", 36, 210, 215, 235);
s02_l2    = text("processing — built in Rust.", "test_inputs/georgia.ttf", 36, 210, 215, 235);
s02_l3    = text("No loops. No buffers. Just expressions.", "test_inputs/georgia.ttf", 32, 140, 148, 180);
s02_l4    = text("Define a filter once. Apply it forever.", "test_inputs/georgia.ttf", 32, 140, 148, 180);

s02_rule = blank(600, 2) -> rule_cyan();
s02_card = blank(800, 360) -> card_bg();

s02 = s02_bg
    -> blend(140, 160, s02_label, 1.0)
    -> blend(140, 248, s02_rule,  1.0)
    -> blend(140, 290, s02_card,  0.95)
    -> blend(170, 320, s02_l1,   1.0)
    -> blend(170, 375, s02_l2,   1.0)
    -> blend(170, 450, s02_l3,   0.9)
    -> blend(170, 505, s02_l4,   0.9);

export(s02, "Outputs/slide_02_what.png");

// ─────────────────────────────────────────────────────────────────────────────
// SLIDE 03 — "Write Filters Like Math" — filter syntax showcase
// ─────────────────────────────────────────────────────────────────────────────
s03_bg = blank(1080, 1080)
    -> navy_bg()
    -> vignette(1.1)
    -> scanlines(5)
    -> grain(3);

s03_heading = text("Write Filters Like Math", "test_inputs/georgia.ttf", 60, 140, 60, 220);
s03_rule    = blank(700, 2) -> rule_cyan();

// Code block on dark card
s03_card  = blank(800, 380) -> card_bg();
 s03_c1    = text("filter brightness(amount) {", "test_inputs/georgia.ttf", 28, 0, 230, 230);
 s03_c2    = text("    r = r + amount;",          "test_inputs/georgia.ttf", 28, 220, 225, 240);
 s03_c3    = text("    g = g + amount;",          "test_inputs/georgia.ttf", 28, 220, 225, 240);
 s03_c4    = text("    b = b + amount;",          "test_inputs/georgia.ttf", 28, 220, 225, 240);
 s03_c5    = text("}",                            "test_inputs/georgia.ttf", 28, 0, 230, 230);
 s03_note  = text("That's it. One filter. Zero boilerplate.", "test_inputs/georgia.ttf", 30, 140, 148, 180);

 s03 = s03_bg
    -> blend(140, 160, s03_heading, 1.0)
    -> blend(140, 242, s03_rule,    1.0)
    -> blend(140, 280, s03_card,    0.95)
    -> blend(165, 305, s03_c1,      1.0)
    -> blend(165, 355, s03_c2,      1.0)
    -> blend(165, 400, s03_c3,      1.0)
    -> blend(165, 445, s03_c4,      1.0)
    -> blend(165, 490, s03_c5,      1.0)
    -> blend(140, 700, s03_note,    0.85);

export(s03, "Outputs/slide_03_filters.png");

