txt5_a = text("POWERED BY RUST", "test_inputs/georgia.ttf", 85, 255, 230, 200);
txt5_b = text("ZERO GARBAGE COLLECTION", "test_inputs/georgia.ttf", 40, 200, 180, 150);

slide5 = base5 -> blend(80, 450, txt5_a, 1.0) -> blend(80, 550, txt5_b, 1.0);
export(slide5, "Outputs/slide_05_engine.png");
print("Rendered Slide 5/15");

// SLIDE 6: PIPELINE ORCHESTRATION (Vaporwave Aesthetic)
base6 = blank(1080, 1080) -> bg_dark_slate() -> vaporwave_horizon(0.75) -> brightness(15);
txt6_a = text("PIPELINE ARCHITECTURE", "test_inputs/georgia.ttf", 68, 68, 68, 255);
txt6_b = text("CONSOLIDATED EXECUTION PASS", "test_inputs/georgia.ttf", 36, 220, 100, 255);

slide6 = base6 -> blend(80, 460, txt6_a, 1.0) -> blend(80, 540, txt6_b, 1.0);
export(slide6, "Outputs/slide_06_piping.png");
print("Rendered Slide 6/15");

// SLIDE 7: MATRIX KERNELS (Spatial Convolution Grid)
base7 = blank(1080, 1080) -> bg_dark_slate() -> grid(120, 60, 70, 90) -> sharpen() -> ui_border_glow(12);
txt7_a = text("SPATIAL CONVOLUTIONS", "test_inputs/georgia.ttf", 72, 120, 220, 255);
txt7_b = text("kernel edge = [[-1,-1],...]", "test_inputs/georgia.ttf", 44, 180, 190, 200);

slide7 = base7 -> blend(80, 450, txt7_a, 1.0) -> blend(80, 540, txt7_b, 1.0);
export(slide7, "Outputs/slide_07_kernels.png");
print("Rendered Slide 7/15");

