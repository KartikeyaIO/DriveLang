txt8_a = text("MATH & TRIG BUILT-IN", "test_inputs/georgia.ttf", 72, 255, 210, 150);
txt8_b = text("sin(), cos(), smooth_lerp()", "test_inputs/georgia.ttf", 46, 200, 180, 160);

slide8 = base8 -> blend(80, 450, txt8_a, 1.0) -> blend(80, 540, txt8_b, 1.0);
