txt3_a = text("PURE BARE-METAL DSL", "test_inputs/georgia.ttf", 72, 0, 0, 255);
txt3_b = text("FOR TERMINAL PEOPLE", "test_inputs/georgia.ttf", 44, 100, 220, 200);

slide3 = base3 -> blend(80, 450, txt3_a, 1.0) -> blend(80, 540, txt3_b, 1.0);
export(slide3, "Outputs/slide_03_solution.png");
print("Rendered Slide 3/15");

