base4 = blank(1080, 1080) -> bg_dark_slate() -> grid(40, 30, 32, 40) -> frame_darken_edges();
txt4_a = text("img -> blur(15)", "test_inputs/georgia.ttf", 56, 100, 220, 150);
txt4_b = text("    -> teal_orange()", "test_inputs/georgia.ttf", 56, 255, 180, 80);
txt4_c = text("export(img,path)", "test_inputs/georgia.ttf", 56, 180, 120, 255);

slide4 = base4 -> blend(100, 380, txt4_a, 1.0) -> blend(100, 460, txt4_b, 1.0) -> blend(100, 540, txt4_c, 1.0);
export(slide4, "Outputs/slide_04_syntax.png");
print("Rendered Slide 4/15");

