// ============================================================================
// DRIVELANG INSTAGRAM LAUNCH CAMPAIGN (15 CAROUSEL SLIDES)
// Resolution: 1080x1080 (1:1 Instagram Square Standard)
// Architecture: Native functional piping, spatial masks, and programmatic borders
// ============================================================================

import std::core;
import std::color;

// ----------------------------------------------------------------------------
// CAMPAIGN DESIGN SYSTEM & PALETTE FILTERS
// ----------------------------------------------------------------------------

// Primary Dark IDE Slate Background
filter bg_dark_slate() {
    r = 18;
    g = 20;
    b = 26;
    a = 255;
}

// Hacker Terminal Green Background
filter bg_terminal_green() {
    r = 10;
    g = 24;
    b = 16;
    a = 255;
}

// Procedural Glowing UI Border
filter ui_border_glow(thickness) {
    let is_border = (x < thickness) or (x > (width - thickness)) or (y < thickness) or (y > (height - thickness));
    
    // Boost neon cyan highlights on the frame boundary
    r = (is_border * 40) + ((not is_border) * r);
    g = (is_border * 220) + ((not is_border) * g);
    b = (is_border * 255) + ((not is_border) * b);
}

// Vignette Frame Anchor
filter frame_darken_edges() {
    let cx = width / 2;
    let cy = height / 2;
    let dist = sqrt(((x - cx) * (x - cx)) + ((y - cy) * (y - cy)));
    let max_d = sqrt((cx * cx) + (cy * cy));
    let falloff = clamp(1.0 - ((dist / max_d) * 0.75), 0.0, 1.0);
    
    r = r * falloff;
    g = g * falloff;
    b = b * falloff;
}

// Math-Driven CRT Scanlines
filter scanlines(intensity) {
    let is_even = (y - floor(y / 2) * 2) == 0;
    let factor = 1.0 - (is_even * intensity);
    r = r * factor;
    g = g * factor;
    b = b * factor;
}

// UI Grid Overlay
filter grid(spacing, grid_r, grid_g, grid_b) {
    let mod_x = x - floor(x / spacing) * spacing;
    let mod_y = y - floor(y / spacing) * spacing;
    let is_line = (mod_x == 0) or (mod_y == 0);
    
    r = (is_line * grid_r) + ((not is_line) * r);
    g = (is_line * grid_g) + ((not is_line) * g);
    b = (is_line * grid_b) + ((not is_line) * b);
}

// Cyberpunk Channel Glitch Slice
filter cyberpunk_glitch(frequency, intensity) {
    let band = floor(y / frequency);
    let is_glitch_row = (band - floor(band / 7) * 7) == 3;
    
    let glitch_r = 255 - r;
    let glitch_g = g * 0.3;
    let glitch_b = 255 - b;
    
    r = clamp((is_glitch_row * intensity * glitch_r) + ((not (is_glitch_row * intensity)) * r), 0, 255);
    g = clamp((is_glitch_row * intensity * glitch_g) + ((not (is_glitch_row * intensity)) * g), 0, 255);
    b = clamp((is_glitch_row * intensity * glitch_b) + ((not (is_glitch_row * intensity)) * b), 0, 255);
}

// Highlight/Shadow Split Toning
filter split_tone(split_point) {
    let luma = r * 0.299 + g * 0.587 + b * 0.114;
    let is_highlight = luma > split_point;
    
    let r_mult = (is_highlight * 1.2) + ((not is_highlight) * 0.85);
    let b_mult = (is_highlight * 0.85) + ((not is_highlight) * 1.2);
    
    r = clamp(r * r_mult, 0, 255);
    b = clamp(b * b_mult, 0, 255);
}

// Radial Neon Horizon Gradient
filter vaporwave_horizon(glow_strength) {
    let cx = width / 2;
    let cy = height / 2;
    let dist = sqrt(((x - cx) * (x - cx)) + ((y - cy) * (y - cy)));
    let max_d = sqrt((cx * cx) + (cy * cy));
    let norm_dist = dist / max_d;
    
    let neon_r = 255 * (1.0 - norm_dist);
    let neon_g = 20 * norm_dist;
    let neon_b = 180 * (0.5 + norm_dist * 0.5);
    
    r = clamp((r * (1.0 - glow_strength)) + (neon_r * glow_strength), 0, 255);
    g = clamp((g * (1.0 - glow_strength)) + (neon_g * glow_strength), 0, 255);
    b = clamp((b * (1.0 - glow_strength)) + (neon_b * glow_strength), 0, 255);
}

// Spatial Blur Kernel Declaration
kernel sharpen = [
    [ 0, -1,  0],
    [-1,  5, -1],
    [ 0, -1,  0]
];

// ============================================================================
// SLIDE RENDER PIPELINE
// ============================================================================

print("Initializing DriveLang Launch Campaign Renderer...");

// SLIDE 1: THE HOOK (Cyberpunk Glitch Intro)
base1 = blank(1080, 1080) -> bg_dark_slate() -> grid(60, 35, 40, 55) -> cyberpunk_glitch(120, 0.85) -> frame_darken_edges();
txt1_a = text("INTRODUCING", "test_inputs/georgia.ttf", 48, 180, 190, 210);
txt1_b = text("DRIVELANG", "test_inputs/georgia.ttf", 120, 255, 80, 120);

slide1 = base1 -> blend(80, 400, txt1_a, 1.0) -> blend(80, 480, txt1_b, 1.0);
export(slide1, "Outputs/slide_01_hook.png");
print("Rendered Slide 1/15");

// SLIDE 2: THE PROBLEM (Muted Grayscale Grit)
base2 = blank(1080, 1080) -> bg_dark_slate() -> noir() -> scanlines(0.4) -> ui_border_glow(8);
txt2_a = text("TIRED OF BLOATED", "test_inputs/georgia.ttf", 64, 200, 200, 200);
txt2_b = text("MEDIA PIPELINES?", "test_inputs/georgia.ttf", 80, 220, 70, 70);

slide2 = base2 -> blend(80, 420, txt2_a, 1.0) -> blend(80, 510, txt2_b, 1.0);
export(slide2, "Outputs/slide_02_problem.png");
print("Rendered Slide 2/15");

// SLIDE 3: THE SOLUTION (High Contrast Geometric Punch)
